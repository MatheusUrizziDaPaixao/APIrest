{
  "info": {
    "_postman_id": "api-organizacao-carros",
    "name": "API Organização de Carros",
    "description": "Collection para gerenciar a frota de veículos conforme as aulas 01 a 07.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Listar Todos os Carros",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/carros",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["carros"]
        },
        "description": "Retorna a lista completa de carros cadastrados."
      }
    },
    {
      "name": "Cadastrar Carro (Exemplo 1)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"modelo\": \"Mustang\",\n  \"marca\": \"Ford\",\n  \"ano\": 2022,\n  \"cor\": \"Vermelho\",\n  \"preco\": 450000\n}"
        },
        "url": {
          "raw": "http://localhost:3000/carros",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["carros"]
        }
      }
    },
    {
      "name": "Buscar Carro por ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/carros/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["carros", "1"]
        }
      }
    },
    {
      "name": "Remover Carro",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/carros/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["carros", "1"]
        }
      }
    },
    {
      "name": "Teste de Validação (Erro Preço Negativo)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"modelo\": \"Fusca\",\n  \"marca\": \"VW\",\n  \"ano\": 1970,\n  \"cor\": \"Azul\",\n  \"preco\": -500\n}"
        },
        "url": {
          "raw": "http://localhost:3000/carros",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["carros"]
        }
      }
    }
  ]
}